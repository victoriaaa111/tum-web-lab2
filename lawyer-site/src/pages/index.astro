---
import '../styles/global.css'
import { getEntry } from 'astro:content'

const hero     = await getEntry('hero', 'hero')
const about    = await getEntry('about', 'about')
const contact  = await getEntry('contact', 'contact')
const services = await getEntry('services', 'services')
const reviews  = await getEntry('reviews', 'reviews')
const mascot = await getEntry('mascot', 'mascot')

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <title>Vitalie Mutruc - Avocatul tău</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script>
      if (window.location.hash) {
        const hash = window.location.hash;
        if (
          hash.includes('invite_token=') ||
          hash.includes('recovery_token=') ||
          hash.includes('confirmation_token=')
        ) {
          window.location.href = '/admin/' + hash;
        }
      }

      if (window.netlifyIdentity) {
          window.netlifyIdentity.on("init", (user) => {
            if (!user) {
              window.netlifyIdentity.on("login", () => {
                document.location.href = "/admin/";
              });
            }
          });
      }
    </script>
  </head>
  <body>
    <header>
      <nav id="navbar">
        <a class="nav-brand" href="#hero-section">VM</a>
        <div class="nav-links">
          <a href="#about-section">Despre mine</a>
          <a href="#services-section">Servicii</a>
          <a href="#reviews-section">Recenzii</a>
          <a href="#contact-section">Contacte</a>
        </div>
      </nav>
    </header>

    <section id = "hero-section">
      <div class="hero-bg-lines">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="hero-content">
        <p class="hero-badge">{hero.data.badge}</p>
        <h1>Avocat<br><em>{hero.data.title}</em></h1>
        <div class="hero-rule"></div>
        <p class="hero-des">{hero.data.description}</p>
        <div class="hero-actions">
          <a href="#contact-section" class="btn-primary">{hero.data.cta_primary}</a>
          <a href="#services-section" class="btn-secondary">{hero.data.cta_secondary}</a>
        </div>
      </div>
    </section>

    <section id = "about-section">
      <div class="section-numeral">II</div>
      <div class="about-inner">
        <div class="section-label">Despre mine</div>
        <div class="about-layout">
          <div class="about-left">
            <h2>Experiență<br><em>și competență</em></h2>
            <div class="section-divider"></div>
          </div>
          <div class="about-right">
              <div class="about-block">
                <div class="about-block-marker">01</div>
                <p>
{about.data.block1}</p>
              </div>
              <div class="about-block">
                <div class="about-block-marker">02</div>
                <p>
{about.data.block2}</p>
              </div>
              <div class="about-block">
                <div class="about-block-marker">03</div>
                <p>
{about.data.block3}</p>
            </div>
          </div>
        </div>
            <div class="about-photo-row">
              <div class="about-photo">
                <img src={about.data.photo} alt="Avocat Vitalie Mutruc" />
                <div class="photo-caption">Vitalie Mutruc - Avocat, Chișinău</div>
              </div>
              <div class="about-quote">
                <blockquote>
&ldquo;{about.data.quote}&rdquo;</blockquote>
              </div>
            </div>
        </div>
    </section>

    <section id = "services-section">
      <div class="section-numeral">III</div>
      <div class="services-inner">
        <div class="section-label light">Servicii juridice</div>
        <h2>Ce<br><em>oferim</em></h2>
        <div class="section-divider light"></div>
        <div class="services-grid">
          {services.data.items
            .sort((a, b) => a.order - b.order)
            .map((service, i) => (
              <div class="service-card">
                <div class="service-card-num">0{i + 1}</div>
                <div class="service-card-body">
                  <h3>{service.title}</h3>
                  <p>{service.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id = "reviews-section"
             class="min-h-[100vh] bg-khaki py-[4rem] px-[1.25rem] box-border relative overflow-hidden flex flex-col justify-center
              tablet:py-[5rem] tablet:px-[2.5rem]
              desktop:py-[7rem] desktop:px-[4rem]">
      <div class="font-cormorant text-[7rem] font-light italic text-taupe/10 absolute right-[1rem] top-[1rem] leading-none pointer-events-none tracking-[-0.04em]">IV</div>
      <div class="max-w-[1100px] my-0 mx-auto w-full">
        <div class="font-dm text-[0.58rem] tracking-[0.22em] uppercase text-taupe mb-[1.25rem] block max-w-[300px] mt-[1rem]">Recenzii</div>
        <h2 class="text-[2.5rem] text-leather
            tablet:text-[3rem]
            desktop:text-[3.5rem]">
          Clienți<br><em>satisfăcuți</em>
        </h2>
        <div class="w-[2.5rem] h-[1px] bg-taupe opacity-50 mt-[1.5rem] mx-0 mb-[0.8rem]"></div>
        <div class="flex flex-col gap-[1rem]
             tablet:grid tablet:grid-cols-2 tablet:gap-[1.25rem]">
          {reviews.data.items
            .sort((a, b) => a.order - b.order)
            .map(review => (
              <div class="bg-vanilla border border-solid border-taupe/15 p-[1.5rem] relative transition-all duration-[300ms] ease-in hover:translate-y-[-3px] hover:shadow-[0_8px_24px_rgba(38,38,38,0.08)] before:content-['“'] before:font-cormorant before:text-[5rem] before:font-light before:text-taupe before:opacity-10 before:absolute before:top-2 before:right-4 before:leading-none">
                <div class="text-[0.6rem] text-taupe tracking-[0.1rem] mb-[0.85rem]">★★★★★</div>
                <p class="font-cormorant text-[1.05rem] italic text-navy-black leading-[1.7] mb-[1rem]">&ldquo;{review.text}&rdquo;</p>
                <div class="text-[0.58rem] font-dm text-taupe uppercase tracking-[0.15em]">- {review.author}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <footer id = "contact-section" class="bg-leather relative overflow-hidden px-[1.25rem] pt-[4rem] pb-[3rem] box-border h-auto
         tablet:px-[2.5rem] tablet:pt-[5rem] tablet:pb-[3.5rem]
         desktop:px-[4rem] desktop:pt-[7rem] desktop:pb-[4rem]">
      <div class="font-cormorant text-[7rem] font-light italic pr-[1.5rem] text-vanilla/5 absolute right-0 top-[1rem] leading-none pointer-events-none tracking-[-0.04em]">
        V
      </div>
      <div class="max-w-[1100px] my-0 mx-auto ">
        <div class="font-dm text-[0.58rem] tracking-[0.22em] uppercase text-taupe mb-[1.25rem] block max-w-[300px] mt-[1rem]">Contacte</div>
        <div class="flex flex-col border-t border-solid border-t-taupe/15 mb-[2.5rem]
              tablet:grid tablet:grid-cols-2
              desktop:grid desktop:grid-cols-4">
          <div class="py-[1.5rem] px-0 border-b border-solid border-b-taupe/15
          desktop:pl-[2rem]
          tablet:pl-[2rem]">
              <span class="block font-dm text-[0.54rem] tracking-[0.22em] uppercase text-taupe mb-[0.5rem]">
                Email
              </span>
              <a href={`mailto:${contact.data.email}`} class="no-underline font-cormorant text-[1.25rem] text-dune font-light transition-colors duration-[180ms] ease-in hover:text-taupe block">
                {contact.data.email}
              </a>
          </div>
          <div class="py-[1.5rem] px-0 border-b border-solid border-b-taupe/15
          desktop:pl-[2rem] desktop:border-l  desktop:border-solid desktop:border-l-taupe/15
          tablet:pl-[2rem] tablet:border-l tablet:border-solid tablet:border-l-taupe/15
">
              <span class=" block font-dm text-[0.54rem] tracking-[0.22em] uppercase text-taupe mb-[0.5rem]">
              Telefon
              </span>
              <a href={`tel:${contact.data.phone}`} class="no-underline font-cormorant text-[1.25rem] text-dune font-light transition-colors duration-[180ms] ease-in hover:text-taupe block">{contact.data.phone}</a>
          </div>
          <div class="py-[1.5rem] px-0 border-b border-solid border-b-taupe/15
          desktop:pl-[2rem] desktop:border-l  desktop:border-solid desktop:border-l-taupe/15
          tablet:pl-[2rem] ">
              <span class="block font-dm text-[0.54rem] tracking-[0.22em] uppercase text-taupe mb-[0.5rem]">
                Adresă birou
              </span>
              <p class="font-cormorant text-[1.25rem] leading-[1.5] font-light text-dune block">
set:html={contact.data.address}</p>
          </div>
          <div class="py-[1.5rem] px-0 border-b border-solid border-b-taupe/15
          desktop:pl-[2rem] desktop:border-l desktop:border-solid desktop:border-l-taupe/15
          tablet:pl-[2rem] tablet:border-l tablet:border-solid tablet:border-l-taupe/15">
              <span class="block font-dm text-[0.54rem] tracking-[0.22em] uppercase text-taupe mb-[0.5rem]">
                Program de lucru
              </span>
              <p class="font-cormorant text-[1.25rem] leading-[1.5] font-light text-dune block">
set:html={contact.data.hours}</p>
          </div>
        </div>
        <div class="flex gap-[0.75rem] flex-wrap">
          <a href={`mailto:${contact.data.email}`} class="inline-flex items-center justify-center py-[0.85rem] px-[1.75rem] bg-taupe text-vanilla font-dm text-[0.6rem] font-medium tracking-[0.18em] uppercase no-underline border border-solid border-leather transition-all ease-in-out duration-[250ms] hover:border-dune hover:bg-leather hover:-translate-y-0.5">Trimite un email</a>
          <a href={`tel:${contact.data.phone}`} class="inline-flex items-center justify-center py-[0.85rem] px-[1.75rem] bg-transparent text-dune font-dm text-[0.6rem] tracking-[0.18em] uppercase no-underline border border-solid border-dune/30 transition-all duration-[250ms] ease-in-out hover:border-dune hover:-translate-y-[2px] tablet:hidden">Sună acum</a>
        </div>
      </div>
    </footer>

    <div class="mascot-outer">
      <div id="mascot-wrapper">
        <div class="mascot-glow"></div>
        <img class="mascot-img" src="/images/mascot.png" alt="Mascota avocatului">
        <div class="mascot-speech">
          <p>
            set:html={mascot.data.message}
          </p>
        </div>
      </div>
    </div>
  </body>
</html>